# ============================================================
# Roadmap Tracker - local environment example
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---------- PostgreSQL ----------
# Used by the FastAPI app via SQLAlchemy async (asyncpg driver)
POSTGRES_USER=roadmap
POSTGRES_PASSWORD=roadmap
POSTGRES_DB=roadmap_tracker
DATABASE_URL=postgresql+asyncpg://roadmap:roadmap@db:5432/roadmap_tracker

# ---------- Redis ----------
# In-memory store for pomodoro timer state + rate limiting
REDIS_URL=redis://redis:6379/0

# ---------- JWT auth ----------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MIN=10080

# ---------- Seed user (single-user local app) ----------
# On first startup the app creates this user and hashes the password.
SEED_USERNAME=kingbrems
SEED_PASSWORD=change-me

# ---------- GitHub sync (optional at M0, used from M6) ----------
# Personal Access Token with `public_repo` scope (read-only public repos).
# Leave empty to disable GitHub sync until you are ready.
GITHUB_TOKEN=

# ---------- Roadmap source ----------
# Path (inside the container) to the markdown file used to seed weeks.
ROADMAP_MD_PATH=/app/roadmap.md

# ---------- App ----------
# Comma-separated list of allowed CORS origins. For local dev include the Vite dev server.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Run uvicorn with --reload when 1 (dev), 0 for production-style
RELOAD=1